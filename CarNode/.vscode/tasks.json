{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "PlatformIO: Build",
            "type": "shell",
            "command": "platformio",
            "args": ["run"],
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "PlatformIO: Upload",
            "type": "shell",
            "command": "platformio",
            "args": ["run", "--target", "upload"],
            "group": {
                "kind": "build"
            },
            "problemMatcher": [
                "$gcc"
            ]
        },
        {
            "label": "PlatformIO: Clean",
            "type": "shell",
            "command": "platformio",
            "args": ["run", "--target", "clean"],
            "group": {
                "kind": "build"
            },
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}
